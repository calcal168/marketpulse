{
  "expo": {
    "name": "MarketPulse",
    "slug": "marketpulse-expo",
    "icon": "./assets/images/icon.png",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "marketpulse",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.marketpulseexpo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoadsInWebContent": true
        }
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "com.example.marketpulseexpo",
      "runtimeVersion": "1.0.0"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65dcb71d-2c86-41e9-83a9-ff7446cf5774"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/65dcb71d-2c86-41e9-83a9-ff7446cf5774"
    }
  }
}
